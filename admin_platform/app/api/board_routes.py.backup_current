@router.get("/board/post/{post_id}", response_class=HTMLResponse)
def view_post(request: Request, post_id: int, db: Session = Depends(get_db)):
    current_user = get_current_user_optional(request, db)
    
    post = db.execute(text("""
        SELECT id, category, title, content, author, created_at, file_path 
        FROM board_posts 
        WHERE id = :post_id
    """), {"post_id": post_id}).fetchone()
    
    if not post:
        raise HTTPException(status_code=404, detail="게시글을 찾을 수 없습니다.")
    
    # 답글 조회
    replies = db.execute(text("""
        SELECT id, content, author, created_at 
        FROM board_replies 
        WHERE post_id = :post_id 
        ORDER BY created_at DESC
    """), {"post_id": post_id}).fetchall()
    
    return templates.TemplateResponse("board_detail.html", {
        "request": request,
        "current_user": current_user,
        "post": post,
        "replies": replies
    })

@router.post("/board/post/{post_id}/reply")
def add_reply(request: Request, post_id: int, content: str = Form(...), db: Session = Depends(get_db)):
    current_user = get_current_user_optional(request, db)
    if not current_user:
        raise HTTPException(status_code=401, detail="로그인이 필요합니다.")
    
    # 게시글 존재 확인
    post = db.execute(text("SELECT id FROM board_posts WHERE id = :post_id"), {"post_id": post_id}).fetchone()
    if not post:
        raise HTTPException(status_code=404, detail="게시글을 찾을 수 없습니다.")
    
    db.execute(text("""
        INSERT INTO board_replies (post_id, content, author, created_at)
        VALUES (:post_id, :content, :author, :created_at)
    """), {
        "post_id": post_id,
        "content": content,
        "author": current_user.name,
        "created_at": datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    })
    db.commit()

    return RedirectResponse(url=f"/board/post/{post_id}", status_code=303)

@router.post("/board/post/{post_id}/like")
def like_post(request: Request, post_id: int, like_type: str = Form(...), db: Session = Depends(get_db)):
    user_ip = request.client.host
    
    # 이미 좋아요/싫어요를 눌렀는지 확인
    existing = db.execute(text("""
        SELECT id FROM board_likes 
        WHERE post_id = :post_id AND user_ip = :user_ip
    """), {"post_id": post_id, "user_ip": user_ip}).fetchone()
    
    if not existing:
        db.execute(text("""
            INSERT INTO board_likes (post_id, like_type, user_ip, created_at)
            VALUES (:post_id, :like_type, :user_ip, :created_at)
        """), {
            "post_id": post_id,
            "like_type": like_type,
            "user_ip": user_ip,
            "created_at": datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        })
        db.commit()

    return RedirectResponse(url="/board", status_code=303)

